{
  "prompt": "List exactly 30 distinct, real, verifiable facts about deep-sea creatures. One fact per line. No headers, no numbering, no commentary.",
  "mode": "nonstream",
  "thinking": "adaptive",
  "max_tokens": 6000,
  "cache_ttl": "1h",
  "conditions": [
    {"label": "effort-low", "args": {"effort": "low"}},
    {"label": "effort-medium", "args": {"effort": "medium"}},
    {"label": "effort-high", "args": {"effort": "high"}},
    {"label": "effort-xhigh", "args": {"effort": "xhigh"}},
    {"label": "effort-max", "args": {"effort": "max"}}
  ]
}
